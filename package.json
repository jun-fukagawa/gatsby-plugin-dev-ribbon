{
  "name": "gatsby-plugin-dev-ribbon",
  "version": "1.0.5",
  "description": "Add a development ribbon to your Gatsby site.",
  "author": "Jun Fukagawa",
  "license": "MIT",
  "keywords": [
    "gatsby",
    "gatsby-plugin",
    "ribbon"
  ],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@emotion/babel-plugin": "^11.13.5",
    "gatsby": "^5.16.1",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "build": "babel ./src --out-dir .",
    "watch": "pnpm build --watch",
    "clean": "rimraf components gatsby-*.js",
    "fix": "prettier --write ./src"
  },
  "peerDependencies": {
    "gatsby": "^3.0.0 || ^4.0.0 || ^5.0.0",
    "react": "^17.0.0 || ^18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jun-fukagawa/gatsby-plugin-dev-ribbon.git"
  },
  "packageManager": "pnpm@11.4.0"
}
